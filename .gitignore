# ============================================================
#  BAS Firmware — .gitignore
#  MPLAB X IDE / XC8 Compiler — PIC18F4580
# ============================================================

# ----------------------------
# MPLAB X build artefacts
# ----------------------------
build/
dist/

# Dependency and preprocessor output
*.d
*.i
*.p1
*.pre

# Compiled object and linker output
*.o
*.obj
*.elf
*.map
*.sym
*.lst

# HEX / binary output  (generated — rebuild to get these)
*.hex
*.bin
*.cof
*.cod

# XC8 intermediate files
*.cmf
*.emf
*.hxl
*.mum

# ----------------------------
# MPLAB X project internals
# ----------------------------
BAS_Firmware.X/nbproject/private/
BAS_Firmware.X/nbproject/private/
BAS_Firmware.X/nbproject/Makefile-*
BAS_Firmware.X/nbproject/Package-*.bash

# Keep these — they define the project
!BAS_Firmware.X/nbproject/configurations.xml
!BAS_Firmware.X/nbproject/project.xml

# ----------------------------
# IDE and OS junk
# ----------------------------

# MPLAB X
*.mplabws
*.mchpresult

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.nfs*

# VS Code
.vscode/

# JetBrains / CLion
.idea/
*.iml

# Emacs
\#*\#
.\#*

